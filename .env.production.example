# ============================================
# SafeScan — Production Environment Variables
# ============================================
# СКОПИРУЙТЕ В .env.production И ЗАПОЛНИТЕ ВСЕ ЗНАЧЕНИЯ
# НИКОГДА НЕ КОММИТЬТЕ .env.production В GIT!

# --- Application ---
APP_NAME=SafeScan
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=erverfsberstgbedfvergervreververv
APP_CORS_ORIGINS=https://testdomen155.ru

# --- Database (Timeweb Managed PostgreSQL) ---
# Формат: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://safescan:<PASSWORD>@pg-xxxxx.dbaas.timeweb.ru:6432/safescan
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# --- Redis (Timeweb Managed Redis) ---
# Формат: redis://:password@host:port/db
REDIS_URL=redis://:<PASSWORD>@redis-xxxxx.dbaas.timeweb.ru:6379/0

# --- JWT ---
JWT_SECRET_KEY=ervevevwecwvfsfdvre
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OAuth2 (опционально) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Email (SMTP) ---
# Timeweb Mail или другой SMTP
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.ru
SMTP_PASSWORD=<SMTP_PASSWORD>
SMTP_FROM=noreply@yourdomain.ru
SMTP_USE_TLS=true

# --- YooKassa ---
YOOKASSA_SHOP_ID=<YOUR_SHOP_ID>
YOOKASSA_SECRET_KEY=<YOUR_SECRET_KEY>
YOOKASSA_RETURN_URL=https://yourdomain.ru/account

# --- Celery ---
CELERY_BROKER_URL=redis://:<PASSWORD>@redis-xxxxx.dbaas.timeweb.ru:6379/1
CELERY_RESULT_BACKEND=redis://:<PASSWORD>@redis-xxxxx.dbaas.timeweb.ru:6379/2

# --- Scan Settings ---
SCAN_MAX_CONCURRENT=5
SCAN_MAX_CRAWL_DEPTH=5
SCAN_MAX_PAGES=500
SCAN_REQUESTS_PER_SECOND=20
SCAN_TIMEOUT_SECONDS=300
SCAN_USER_AGENT=SafeScan/1.0 (+https://yourdomain.ru)
SCAN_PROXY_ENABLED=false
SCAN_PROXY_LIST=

# --- Storage (Timeweb Object Storage / S3) ---
S3_ENDPOINT_URL=https://s3.timeweb.cloud
S3_ACCESS_KEY=<S3_ACCESS_KEY>
S3_SECRET_KEY=<S3_SECRET_KEY>
S3_BUCKET=safescan-reports
S3_REGION=ru-1

# --- Compliance ---
DATA_RETENTION_DAYS=90
ENABLE_AUDIT_LOG=true

# --- Domain ---
DOMAIN=yourdomain.ru

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://yourdomain.ru/api/v1
