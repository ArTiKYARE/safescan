# Текстовые файлы — всегда LF (Linux-style)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.sql text eol=lf

# Бинарные файлы — без конвертации
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Docker/Compose файлы
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
Caddyfile text eol=lf

# Windows-specific файлы — CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
